{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "fmt": {
      "outputs": [
        "{projectRoot}/."
      ],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "fmt:check": {
      "cache": true
    }
  },
  "workspaceLayout": {
    "appsDir": "apps"
  },
  "defaultProject": "backend",
  "analytics": false,
  "plugins": [
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "vitest:test",
        "ciTargetName": "test-ci",
        "testMode": "watch"
      }
    }
  ],
  "neverConnectToCloud": true
}
