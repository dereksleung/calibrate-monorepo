{
  "name": "@calibrate/api-contracts",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "nx": {
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "cwd": "packages/api-contracts",
          "command": "vitest run src"
        }
      },
      "test:integration": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "cwd": "packages/api-contracts",
          "command": "vitest run --passWithNoTests \"src/**/*.integration.test.ts\" \"integration/**/*.test.ts\" \"test/integration/**/*.test.ts\""
        }
      },
      "test:e2e": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "cwd": "packages/api-contracts",
          "command": "vitest run --passWithNoTests \"src/**/*.e2e.test.ts\" \"e2e/**/*.test.ts\" \"test/e2e/**/*.test.ts\""
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "cache": true,
        "options": {
          "cwd": "packages/api-contracts",
          "command": "tsc -b tsconfig.json"
        }
      }
    }
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
