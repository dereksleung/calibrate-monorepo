{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "backend",
  "projectType": "application",
  "sourceRoot": "apps/backend/src",
  "tags": ["type:app", "scope:backend"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "nodemon --exec \"tsx --tsconfig apps/backend/tsconfig.json\" apps/backend/src/app.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "options": {
        "command": "tsdown",
        "cwd": "apps/backend"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "docker build -f apps/backend/Dockerfile -t dereksleung407/calibrate:latest ."
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node apps/backend/dist/app.mjs"
      }
    },
    "kysely": {
      "executor": "nx:run-commands",
      "options": {
        "command": "kysely --config=apps/backend/kysely.config.ts --experimental-resolve-tsconfig-paths"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/backend",
        "command": "vitest run --exclude \"**/*.integration.test.ts\" --exclude \"**/*.e2e.test.ts\" --exclude \"integration/**\" --exclude \"e2e/**\" --exclude \"test/integration/**\" --exclude \"test/e2e/**\""
      }
    },
    "test-ci": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/backend",
        "command": "vitest run --exclude \"**/*.integration.test.ts\" --exclude \"**/*.e2e.test.ts\" --exclude \"integration/**\" --exclude \"e2e/**\" --exclude \"test/integration/**\" --exclude \"test/e2e/**\""
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/backend",
        "command": "vitest run --passWithNoTests \"src/**/*.integration.test.ts\" \"integration/**/*.test.ts\" \"test/integration/**/*.test.ts\""
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "apps/backend",
        "command": "vitest run --passWithNoTests \"src/**/*.e2e.test.ts\" \"e2e/**/*.test.ts\" \"test/e2e/**/*.test.ts\""
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/backend",
        "command": "vitest --watch --exclude \"**/*.integration.test.ts\" --exclude \"**/*.e2e.test.ts\" --exclude \"integration/**\" --exclude \"e2e/**\" --exclude \"test/integration/**\" --exclude \"test/e2e/**\""
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "oxlint --type-aware --type-check --tsconfig apps/backend/tsconfig.json apps/backend"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "oxlint --config .oxlintrc.json apps/backend"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint --fix --config .oxlintrc.json apps/backend"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/."],
      "cache": true,
      "options": {
        "command": "oxfmt apps/backend"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "oxfmt --check apps/backend"
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/backend/dist/package.json",
        "{workspaceRoot}/apps/backend/dist/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/backend/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    }
  }
}
