{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude \"**/*.integration.test.{ts,tsx}\" --exclude \"**/*.e2e.test.{ts,tsx}\" --exclude \"integration/**\" --exclude \"e2e/**\" --exclude \"test/integration/**\" --exclude \"test/e2e/**\"",
    "test:integration": "vitest run --passWithNoTests \"src/**/*.integration.test.{ts,tsx}\" \"integration/**/*.test.{ts,tsx}\" \"test/integration/**/*.test.{ts,tsx}\"",
    "test:e2e": "vitest run --passWithNoTests \"src/**/*.e2e.test.{ts,tsx}\" \"e2e/**/*.test.{ts,tsx}\" \"test/e2e/**/*.test.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "fmt": "prettier --write ."
  },
  "dependencies": {
    "@calibrate/api-contracts": "1.0.0",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/manrope": "5.2.8",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-router": "1.168.24",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/router-plugin": "1.167.27",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.545.0",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/router-plugin": "1.167.27",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "jsdom": "28.1.0",
    "shadcn": "4.5.0",
    "storybook": "10.3.5",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.4"
  }
}
