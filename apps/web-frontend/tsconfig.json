{
  "extends": "../../tsconfig.base.json",
  "files": [], // intentionally empty
  "include": ["**/*.ts", "**/*.tsx"],
  "outDir": "./dist",
  "rootDir": ".",
  "references": [
    { "path": "../../packages/api-contracts" },
    { "path": "../../packages/api-client" }
  ],
  "compilerOptions": {
    "composite": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@calibrate/api-client": ["../../packages/api-client/src/index.ts"],
      "@calibrate/api-contracts": ["../../packages/api-contracts/src/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
